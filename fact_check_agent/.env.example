# ── Inherited from memory_agent (use the same values) ────────────────────────
OPENAI_API_KEY=
NEO4J_URI=
NEO4J_USER=neo4j
NEO4J_PASSWORD=
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
TAVILY_API_KEY=
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ── LLM provider toggle ───────────────────────────────────────────────────────
# Set to "ollama" to use a local Ollama deployment instead of OpenAI cloud API.
LLM_PROVIDER=openai
# WARNING: changing EMBEDDING_PROVIDER requires flushing and re-seeding ChromaDB
# because embedding dimensions differ (OpenAI: 1536, nomic-embed-text: 768).
EMBEDDING_PROVIDER=openai

# ── Ollama settings (ignored when *_PROVIDER=openai) ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_LLM_MODEL=gemma4:e2b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── LangSmith tracing ─────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=fakenews-factcheck
