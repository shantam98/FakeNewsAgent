# ── Inherited from memory_agent (use the same values) ────────────────────────
OPENAI_API_KEY=

# Neo4j — local Docker (recommended for dev)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fakenews123
# Neo4j Aura cloud alternative:
# NEO4J_URI=neo4j+s://<instance>.databases.neo4j.io
# NEO4J_USER=<username>
# NEO4J_PASSWORD=<password>

# ChromaDB — local Docker (recommended for dev)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_API_KEY=
CHROMA_TENANT=
CHROMA_DATABASE=
# ChromaDB Cloud alternative:
# CHROMA_API_KEY=<key>
# CHROMA_TENANT=<tenant>
# CHROMA_DATABASE=<database>

TAVILY_API_KEY=
LLM_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small

# ── LLM provider toggle ───────────────────────────────────────────────────────
# Set to "ollama" to use a local Ollama deployment instead of OpenAI cloud API.
LLM_PROVIDER=openai
# WARNING: changing EMBEDDING_PROVIDER requires flushing and re-seeding ChromaDB
# because embedding dimensions differ (OpenAI: 1536, nomic-embed-text: 768).
EMBEDDING_PROVIDER=openai

# ── Ollama settings (ignored when *_PROVIDER=openai) ─────────────────────────
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_LLM_MODEL=gemma4:e2b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# Vision-language model for benchmark caption generation (e.g. llava:7b, moondream, gemma3:4b)
# Leave blank to skip caption generation (use SigLIP or no cross-modal check instead)
OLLAMA_VLM_MODEL=

# ── Langfuse observability ────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000
# Set to false to suppress Langfuse tracing errors when server is not running
LANGFUSE_TRACING_ENABLED=false
LANGFUSE_ENABLED=false

# ── LangSmith tracing ─────────────────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=fakenews-factcheck

# ── Retrieval enhancements ────────────────────────────────────────────────────
USE_GRAPH_RAG=false
USE_CROSS_ENCODER=false
CROSS_ENCODER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=5

# ── SOTA flags — enable one at a time to measure impact ──────────────────────

# S5: SigLIP cross-modal check (local, no LLM call)
USE_SIGLIP=false
SIGLIP_MODEL=google/siglip-base-patch16-224
SIGLIP_THRESHOLD=0.10

# S2: Adaptive retrieval gate — skip Tavily when memory context is sufficient
USE_RETRIEVAL_GATE=false

# S3: Claim decomposition — split compound claims into atomic sub-claims
USE_CLAIM_DECOMPOSITION=false

# S4: Multi-agent debate — advocate/arbiter loop for low-confidence verdicts
USE_DEBATE=false
DEBATE_CONFIDENCE_THRESHOLD=70

# S6: Freshness ReAct agent — LLM can call Tavily before deciding freshness
USE_FRESHNESS_REACT=false

# ── Benchmark / evaluation ────────────────────────────────────────────────────
# DRY_RUN: skip all DB writes (ChromaDB + Neo4j) — Docker still needed for reads
DRY_RUN=false
# OFFLINE_MODE: skip all DB reads+writes — no Docker needed at all (implies DRY_RUN)
OFFLINE_MODE=false
